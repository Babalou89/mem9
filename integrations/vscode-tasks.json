{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mem9: sync memories to .clinerules",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "${userHome}/Documents/gitrepo/mem9/integrations/roo-mem9-sync.ps1",
        "-ProjectPath", "${workspaceFolder}"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "mem9: save selection as memory",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "${userHome}/Documents/gitrepo/mem9/integrations/ollama-mem9.ps1",
        "-Save", "${selectedText}"
      ],
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}
